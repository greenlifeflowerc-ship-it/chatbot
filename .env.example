# Runtime
NODE_ENV=production
PORT=10000
LOG_LEVEL=info

# Supabase
SUPABASE_URL=
# Service-role key — backend only, never ship to Flutter
SUPABASE_SERVICE_ROLE_KEY=
# Public anon key — served to the Flutter app via GET /config
SUPABASE_ANON_KEY=
# Optional: restrict browser origins for CORS (comma-separated). Unset = allow any.
CORS_ORIGINS=

# Meta / Instagram
# Webhook signature key (NOT a token). Optional if IG_APP_SECRET is set — the
# verifier accepts either secret.
META_APP_SECRET=
META_VERIFY_TOKEN=
GRAPH_BASE=https://graph.instagram.com
GRAPH_VERSION=v23.0

# Instagram Business Login (OAuth) — connect by logging in; the token is captured
# and refreshed automatically. From the Meta app: Instagram -> API setup with
# Instagram login (app id + secret), and register the redirect URI there.
IG_APP_ID=
IG_APP_SECRET=
IG_REDIRECT_URI=
# Random string you choose; required as ?secret=... to start the connect flow.
IG_SETUP_SECRET=
# Optional manual fallback token (leave blank when using Login with Instagram).
IG_ACCESS_TOKEN=

# AI is OPTIONAL. With no generation key the bot sends AUTO_REPLY_MESSAGE and
# routes every chat to a human.
# Choose ONE generation provider via LLM_PROVIDER: anthropic OR groq.
LLM_PROVIDER=groq
# Anthropic (LLM_PROVIDER=anthropic)
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
# Groq — free + fast (LLM_PROVIDER=groq). Key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Voice transcription + image understanding (uses GROQ_API_KEY).
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Embeddings are OPTIONAL. With no OPENAI_API_KEY the bot includes the knowledge
# base text directly instead of vector search (works fine with Groq alone).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Sent when AI is off or unavailable (then handed to a human).
AUTO_REPLY_MESSAGE=Thanks for your message! Someone from our team will reply shortly.

# RAG tuning (optional — sensible defaults applied if unset)
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.2
RAG_MAX_HISTORY=8

# Concurrency / reliability (optional)
WORKER_CONCURRENCY=4
LLM_CONCURRENCY=3
HTTP_MAX_RETRIES=4
