# Runtime
NODE_ENV=production
PORT=10000
LOG_LEVEL=info

# Supabase (service-role key — backend only, never ship to Flutter)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Meta / Instagram
META_APP_SECRET=
META_VERIFY_TOKEN=
IG_ACCESS_TOKEN=
GRAPH_BASE=https://graph.instagram.com
GRAPH_VERSION=v23.0

# LLM (generation)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# RAG tuning (optional — sensible defaults applied if unset)
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.2
RAG_MAX_HISTORY=8

# Concurrency / reliability (optional)
WORKER_CONCURRENCY=4
LLM_CONCURRENCY=3
HTTP_MAX_RETRIES=4
